#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "winres.h"
#undef APSTUDIO_READONLY_SYMBOLS

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

IDD_PREFERENCES DIALOGEX 0, 0, 380, 184
STYLE DS_SETFONT | WS_CHILD
FONT 8, "Microsoft Sans Serif", 400, 0, 0x0
BEGIN
    LTEXT           "SQLite DB:",IDC_STATIC,7,10,60,8
    EDITTEXT        IDC_EDIT_DB_PATH,72,8,250,12,ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...",IDC_BTN_BROWSE_DB,328,7,45,14
    LTEXT           "Spotify Client ID:",IDC_STATIC,7,32,70,8
    EDITTEXT        IDC_EDIT_CLIENT_ID,88,30,285,12,ES_AUTOHSCROLL
    LTEXT           "Default Device ID:",IDC_STATIC,7,54,76,8
    EDITTEXT        IDC_EDIT_DEVICE_ID,88,52,285,12,ES_AUTOHSCROLL
    LTEXT           "Polling interval ms:",IDC_STATIC,7,76,76,8
    EDITTEXT        IDC_EDIT_POLLING_INTERVAL,88,74,70,12,ES_NUMBER
    AUTOCHECKBOX    "Mute Spotify on sync",IDC_CHECK_MUTE_ON_SYNC,7,98,120,10
    AUTOCHECKBOX    "Follow Spotify playback in foobar2000",IDC_CHECK_FOLLOW_SPOTIFY,7,112,170,10
    PUSHBUTTON      "Login Spotify",IDC_BTN_LOGIN,7,132,78,14
    PUSHBUTTON      "Clear Token",IDC_BTN_CLEAR_TOKEN,92,132,70,14
    LTEXT           "",IDC_STATIC_STATUS,7,160,366,18
END

IDD_URI_DIALOG DIALOGEX 0, 0, 360, 86
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Set Spotify URI"
FONT 8, "Microsoft Sans Serif", 400, 0, 0x0
BEGIN
    LTEXT           "",IDC_STATIC_TRACK,7,8,346,18
    LTEXT           "Spotify URI or URL:",IDC_STATIC,7,32,76,8
    EDITTEXT        IDC_EDIT_SPOTIFY_URI,86,30,267,12,ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,245,62,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,303,62,50,14
END
